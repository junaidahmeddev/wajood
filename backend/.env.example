# ═══════════════════════════════════════════════
# WAJOOD Backend — Environment Variables Example
# Copy this to .env and adjust values as needed
# ═══════════════════════════════════════════════

# Application
APP_NAME=WAJOOD
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://wajood:wajood123@postgres:5432/wajood
SYNC_DATABASE_URL=postgresql://wajood:wajood123@postgres:5432/wajood

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-Compatible Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=wajood
MINIO_SECRET_KEY=wajood123
MINIO_SECURE=False
MINIO_BUCKET_NAME=wajood-photos

# JWT Authentication
JWT_SECRET_KEY=wajood-super-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Notifications
NOTIFICATION_BACKEND=console
